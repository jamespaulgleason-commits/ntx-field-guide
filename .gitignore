# =====================================================================
#  Texas Peace Officer Field Guide - .gitignore
#
#  Track SOURCE only. Everything below is either generated, vendored,
#  or junk. If a file can be rebuilt or re-downloaded, it does not
#  belong in the repo.
# =====================================================================

# ---- Build artifacts (regenerated by build.py - never hand-edit, never commit) ----
index.html
dist/

# ---- Archives (deploy bundles, downloads, backups) ----
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# ---- Node dependencies (re-installable via `npm install`) ----
#  package.json and package-lock.json ARE tracked - they pin the versions.
#  node_modules is NOT: thousands of files, fully reproducible.
node_modules/

# ---- Large vendored binaries ----
#  Copied into the deploy bundle but NOT source. ~33 MB total, they never
#  change, and plain Git handles them badly. Keep a pristine copy somewhere
#  safe and copy them in at zip time.
#  To version them anyway: delete these lines and install Git LFS FIRST.
models/
vendor/
fonts/
icons/

# ---- Stray installers / binaries that landed in the folder ----
git
git.exe
*.msi
*.exe

# ---- Editor / OS noise ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ---- Scratch ----
*.bak
*.orig
*.tmp
*.log
